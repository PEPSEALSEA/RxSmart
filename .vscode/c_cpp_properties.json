{
  "version": 4,
  "configurations": [
    {
      "name": "Win32-ArduinoESP32",
      "includePath": [
        "${workspaceFolder}/**",
        "${env:USERPROFILE}/Documents/Arduino/**",
        "${env:LOCALAPPDATA}/Arduino15/packages/**"
      ],
      "defines": [
        "ARDUINO=10819",
        "ARDUINO_ARCH_ESP32",
        "ESP32"
      ],
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ]
}
